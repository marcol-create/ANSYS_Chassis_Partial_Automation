# =====================================================================
#  DRIVE MECHANICAL FROM WORKBENCH  --  mesh the bumper blocks
# =====================================================================
#  Run from the Workbench Project window:
#     File > Scripting > Run Script File...  -> pick THIS file
#
#  For each Mechanical Model block listed in BUMPERS, this opens
#  Mechanical automatically, sets every (surface) body to 1 mm thick,
#  sets a 3 mm global mesh, generates the mesh, then closes it.
#  No need to open Mechanical by hand for each one.
#
#  Requires: geometry already attached to those Model blocks.
# =====================================================================

# Titles must match the block names on the schematic EXACTLY.
BUMPERS = ["Side bumper", "Front Bumper"]

# How to open Mechanical:
#   ""              -> model.Edit()                 (visible; most reliable)
#   "Interactive"   -> model.Edit(Interactive=False)(hands-off, no GUI use)
#   "Hidden"        -> model.Edit(Hidden=True)      (hidden window)
EDIT_MODE = "Interactive"

# --- Mechanical-side script (runs INSIDE Mechanical via SendCommand) -
# Uses Mechanical's ACT globals (ExtAPI, Quantity, Transaction, ...).
MECH_CMD = '''
THICKNESS    = Quantity("1 [mm]")
ELEMENT_SIZE = Quantity("3 [mm]")
model  = ExtAPI.DataModel.Project.Model
bodies = model.GetChildren(DataModelObjectCategory.Body, True)
with Transaction():
    for body in bodies:
        try:
            body.Thickness = THICKNESS      # surface bodies only
        except Exception:
            pass                            # skip solids / non-surface
mesh = model.Mesh
mesh.ElementSize = ELEMENT_SIZE
mesh.UseAdaptiveSizing = False
mesh.GenerateMesh()
'''


def system_by_title(title):
    want = title.strip().lower()
    for s in GetAllSystems():
        try:
            if want in s.DisplayText.strip().lower():
                return s
        except Exception:
            pass
    return None


def open_model(model):
    if EDIT_MODE == "Interactive":
        model.Edit(Interactive=False)
    elif EDIT_MODE == "Hidden":
        model.Edit(Hidden=True)
    else:
        model.Edit()


for title in BUMPERS:
    sysx = system_by_title(title)
    if sysx is None:
        print("SKIP - system not found: %s" % title)
        continue
    try:
        comp = sysx.GetComponent(Name="Model")
        comp.Refresh()
        model = sysx.GetContainer(ComponentName="Model")
        open_model(model)
        model.SendCommand(Language="Python", Command=MECH_CMD)
        model.Exit()
        print("Meshed: %s" % title)
    except Exception, ex:                   # IronPython 2.x syntax
        print("ERROR on '%s': %s" % (title, ex))

# Persist results to the project file (ignored if project not yet saved).
try:
    Save(Overwrite=True)
    print("Project saved.")
except Exception, ex:
    print("Not saved (save the project manually): %s" % ex)

print("Done.")
